{
  "name": "phantom-auth0",
  "displayName": "Phantom Auth0",
  "version": "1.0.2",
  "description": "Restricted browser agent with Auth0-backed connected accounts, delegated actions, and approval gates.",
  "author": "Younes Laaroussi hello@youneslaaroussi.ca",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@plasmohq/messaging": "^0.7.2",
    "@xenova/transformers": "^2.17.2",
    "css-selector-generator": "^3.8.1",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.304",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "autoprefixer": "^10.4.20",
    "plasmo": "^0.90.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "sidePanel",
      "storage",
      "scripting",
      "tabs",
      "tabCapture",
      "debugger"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self';"
    },
    "host_permissions": [
      "<all_urls>"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "commands": {
      "toggle-listening": {
        "suggested_key": {
          "default": "Alt+P"
        },
        "description": "Toggle Phantom voice input"
      }
    },
    "web_accessible_resources": [
      {
        "resources": [
          "assets/*",
          "assets/**/*"
        ],
        "matches": [
          "<all_urls>"
        ]
      }
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lmdb",
      "msgpackr-extract",
      "protobufjs",
      "sharp"
    ]
  }
}
